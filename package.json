{
  "name": "brand-content-intelligence-xhs",
  "version": "1.14.9",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node --no-warnings src/server.mjs",
    "electron": "electron .",
    "pack": "electron-builder --win --x64",
    "xhs": "node --no-warnings src/cli.mjs",
    "mcp": "node --no-warnings src/mcpServer.mjs",
    "check": "node tests/syntax-check.mjs",
    "test": "npm run check && npm run test:core && npm run test:scheduler && npm run test:playwright-fallback && npm run test:mcp && npm run test:eagle && npm run test:download-template && npm run test:clipboard && npm run test:links-merge && npm run test:storage-filter && npm run test:cursor-filter && npm run test:should-fallback && npm run test:scheduler-suspend && npm run test:cookie-auth && npm run test:cookie-refresh && npm run test:follow-dedup && npm run test:server",
    "test:core": "node --no-warnings tests/core-regression-test.mjs",
    "test:scheduler": "node --no-warnings tests/scheduler-regression-test.mjs",
    "test:playwright-fallback": "node --no-warnings tests/playwright-fallback-test.mjs",
    "test:server": "node --no-warnings tests/server-integration-test.mjs",
    "test:xhs": "node --no-warnings tests/minimal-xhs-test.mjs",
    "test:mcp": "node --no-warnings tests/mcp-smoke-test.mjs",
    "test:eagle": "node --no-warnings tests/eagle-export-metadata-test.mjs",
    "test:download-template": "node --no-warnings tests/download-name-template-test.mjs",
    "test:clipboard": "node --no-warnings tests/clipboard-test.mjs",
    "test:links-merge": "node --no-warnings tests/links-merge-test.mjs",
    "test:storage-filter": "node --no-warnings tests/storage-filter-test.mjs",
    "test:cursor-filter": "node --no-warnings tests/cursor-physical-filter-test.mjs",
    "test:should-fallback": "node --no-warnings tests/should-fallback-test.mjs",
    "test:scheduler-suspend": "node --no-warnings tests/scheduler-suspend-on-cookie-error-test.mjs",
    "test:cookie-auth": "node --no-warnings tests/cookie-auth-state-test.mjs",
    "test:cookie-refresh": "node --no-warnings tests/cookie-refresh-lifecycle-test.mjs",
    "test:follow-dedup": "node --no-warnings tests/follow-account-dedup-test.mjs",
    "test:audit-crawl": "node --no-warnings tests/crawl-chain-audit-test.mjs"
  },
  "dependencies": {
    "chart.js": "^4.4.7",
    "esbuild": "^0.28.1",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "nexe": "^5.0.0-beta.4",
    "playwright": "^1.54.0",
    "sharp": "^0.33.0"
  },
  "build": {
    "appId": "com.brandmedia.tool",
    "productName": "鍝佺墝鍐呭鎯呮姤宸ュ叿",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "src/**/*.mjs",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "public/**/*",
      "src/**/*.mjs"
    ],
    "extraResources": [
      {
        "from": ".browser-cache/chromium-1223",
        "to": "chromium-1223"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}

